{
  "schema": "brainflow.change_set.v2",
  "t": 1773160516,
  "rationale": "Add a procedural policy to minimize Windows CLI argument length risk by standardizing file-based payload passing.",
  "edits": [
    {
      "path": "memory/procedural/cli_arglength_policy.json",
      "content": "{\n  \"schema\": \"brainflow.procedural_policy.v1\",\n  \"name\": \"cli_arglength_policy\",\n  \"priority\": 80,\n  \"rules\": [\n    {\n      \"id\": \"prefer_response_files\",\n      \"when\": \"command_payload_bytes_gt_4096\",\n      \"action\": \"write_payload_to_temp_file_and_pass_path\"\n    },\n    {\n      \"id\": \"avoid_inline_json\",\n      \"when\": \"payload_contains_json\",\n      \"action\": \"use_file_flag_instead_of_inline\"\n    }\n  ]\n}\n"
    }
  ],
  "risks": [
    "If not yet consumed by runtime, policy may have no immediate effect."
  ],
  "expected_benefit": [
    "Reduces risk of Windows CLI arg-length errors by encouraging file-based payload passing."
  ],
  "proposal_id": "proposal-20260311-003516"
}